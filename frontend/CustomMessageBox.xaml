<Window x:Class="SeeMusicApp.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提示" Height="220" Width="400"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="24" Background="White" BorderBrush="#F1F5F9" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.12" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="25,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <TextBlock x:Name="TxtTitle" Text="提示" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#94A3B8"/>
                </Button>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="0,15,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border x:Name="IconBorder" Width="44" Height="44" CornerRadius="22" Background="#EFF6FF" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="IconText" Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="TxtMessage" Grid.Column="1" Text="提示内容" FontSize="14" Foreground="#475569" TextWrapping="Wrap" VerticalAlignment="Center" Margin="15,0,0,0" LineHeight="20"/>
            </Grid>

            <!-- Actions -->
            <Grid Grid.Row="2">
                <Button x:Name="BtnOk" Content="确定" Foreground="White" HorizontalAlignment="Right" Width="100" Padding="0,10" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="BtnOk_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" Background="#457b9d" CornerRadius="12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#1d3557"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
