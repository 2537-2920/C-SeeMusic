<Window x:Class="SeeMusicApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录 - SeeMusic" Height="768" Width="1024"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="AcrylicLoginCard" TargetType="Border">
            <Setter Property="Background" Value="#BFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="40"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#1F2687" Opacity="0.1" BlurRadius="35" ShadowDepth="15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="Control">
            <Setter Property="Background" Value="#80FFFFFF"/>
            <Setter Property="BorderBrush" Value="#33457b9d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="40,12,15,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="15">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E6FFFFFF"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#E6FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#457b9d"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#457b9d"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15" Padding="0,15">
                            <Border.Effect>
                                <DropShadowEffect Color="#457b9d" BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1d3557"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#457b9d"/>
            <Setter Property="BorderBrush" Value="#457b9d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="15" Padding="0,15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0C457b9d"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#fdfbfb" Offset="0"/>
                <GradientStop Color="#ebedee" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Viewbox Stretch="Fill" IsHitTestVisible="False" Opacity="0.05">
                <Canvas Width="100" Height="100">
                    <Line X1="0" Y1="15" X2="100" Y2="15" Stroke="Black" StrokeThickness="0.2"/>
                    <Line X1="0" Y1="17" X2="100" Y2="17" Stroke="Black" StrokeThickness="0.2"/>
                    <Line X1="0" Y1="19" X2="100" Y2="19" Stroke="Black" StrokeThickness="0.2"/>
                    <Line X1="0" Y1="21" X2="100" Y2="21" Stroke="Black" StrokeThickness="0.2"/>
                    <Line X1="0" Y1="23" X2="100" Y2="23" Stroke="Black" StrokeThickness="0.2"/>

                    <Line X1="0" Y1="77" X2="100" Y2="77" Stroke="Black" StrokeThickness="0.2"/>
                    <Line X1="0" Y1="79" X2="100" Y2="79" Stroke="Black" StrokeThickness="0.2"/>
                    <Line X1="0" Y1="81" X2="100" Y2="81" Stroke="Black" StrokeThickness="0.2"/>
                    <Line X1="0" Y1="83" X2="100" Y2="83" Stroke="Black" StrokeThickness="0.2"/>
                    <Line X1="0" Y1="85" X2="100" Y2="85" Stroke="Black" StrokeThickness="0.2"/>
                </Canvas>
            </Viewbox>

            <Canvas x:Name="DecorationCanvas" IsHitTestVisible="False"/>

            <Border Style="{StaticResource AcrylicLoginCard}" Width="420" Padding="40" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>

                    <Button Background="Transparent" BorderThickness="0" Foreground="#999" Cursor="Hand" HorizontalAlignment="Left" Margin="-10,-10,0,20" Click="BtnBack_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="返回主页" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <TextBlock x:Name="TxtTitle" Text="欢迎回来" FontSize="32" FontWeight="Bold" Foreground="#1d3557" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtSubtitle" Text="让灵感在五线谱上自由流淌" FontSize="14" Foreground="#999" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                    <StackPanel x:Name="FormPanel" Margin="0,0,0,10">

                        <TextBlock Text="用户名" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="5,0,0,5"/>
                        <Grid Margin="0,0,0,15">
                            <TextBox Style="{StaticResource InputBoxStyle}"/>
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="#AAA" FontSize="16" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </Grid>

                        <TextBlock Text="密码" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="5,0,0,5"/>
                        <Grid Margin="0,0,0,15">
                            <PasswordBox Style="{StaticResource InputBoxStyle}"/>
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="#AAA" FontSize="16" VerticalAlignment="Center" Margin="15,0,0,0"/>
                        </Grid>

                        <StackPanel x:Name="ConfirmPwdPanel" Visibility="Collapsed">
                            <TextBlock Text="确认密码" FontSize="12" FontWeight="Bold" Foreground="#888" Margin="5,0,0,5"/>
                            <Grid Margin="0,0,0,15">
                                <PasswordBox Style="{StaticResource InputBoxStyle}"/>
                                <TextBlock Text="&#xE73A;" FontFamily="Segoe MDL2 Assets" Foreground="#AAA" FontSize="16" VerticalAlignment="Center" Margin="15,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="BtnSubmit" Style="{StaticResource PrimaryBtnStyle}" Margin="0,10,0,20" Click="BtnSubmit_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="IconSubmit" Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtSubmit" Text="立即登录" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Grid Margin="0,0,0,20">
                        <Line X1="0" Y1="0" X2="400" Y2="0" Stroke="#E0E0E0" StrokeThickness="1" VerticalAlignment="Center"/>
                        <TextBlock Text="或" Background="#FDFBFB" Padding="10,0" Foreground="#CCC" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Grid>

                    <Button Style="{StaticResource SecondaryBtnStyle}" Click="BtnSwitchMode_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="IconSwitch" Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtSwitch" Text="创建新账号" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                        <TextBlock Text="忘记密码？" Foreground="#AAA" FontSize="12" Cursor="Hand"/>
                        <TextBlock Text=" • " Foreground="#AAA" FontSize="12" Margin="10,0"/>
                        <TextBlock Text="隐私政策" Foreground="#AAA" FontSize="12" Cursor="Hand"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>