<Window x:Class="SeeMusicApp.EditProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改个人资料" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border Background="White" BorderThickness="1" BorderBrush="#E2E8F0" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1"/>
        </Border.Effect>
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="修改个人资料" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="更新您的个人信息和头像" FontSize="12" Foreground="#94A3B8" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- 内容区域 -->
            <StackPanel Grid.Row="1" Grid.IsSharedSizeScope="True">
                <!-- 显示名称 -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="显示名称" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border Background="#F8FAFC" BorderThickness="1" BorderBrush="#E2E8F0">
                        <TextBox x:Name="TxtDisplayName" Background="Transparent" BorderThickness="0" Padding="12,10" 
                                 FontSize="14" Foreground="#1E293B" CaretBrush="#457b9d"/>
                    </Border>
                </StackPanel>

                <!-- 邮箱地址 -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="邮箱地址" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border Background="#F8FAFC" BorderThickness="1" BorderBrush="#E2E8F0">
                        <TextBox x:Name="TxtEmail" Background="Transparent" BorderThickness="0" Padding="12,10" 
                                 FontSize="14" Foreground="#1E293B" CaretBrush="#457b9d"/>
                    </Border>
                </StackPanel>

                <!-- 个人简介 -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="个人简介" FontSize="13" FontWeight="Medium" Foreground="#475569" Margin="0,0,0,8"/>
                    <Border Background="#F8FAFC" BorderThickness="1" BorderBrush="#E2E8F0">
                        <TextBox x:Name="TxtBio" Background="Transparent" BorderThickness="0" Padding="12,10" 
                                 FontSize="14" Foreground="#1E293B" CaretBrush="#457b9d" 
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="80" VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="BtnCancel" Content="取消" Width="100" Height="40" 
                        Background="Transparent" Foreground="#64748B" BorderThickness="1" BorderBrush="#E2E8F0"
                        FontSize="14" Cursor="Hand" Click="BtnCancel_Click" Margin="0,0,15,0"/>
                <Button x:Name="BtnSave" Content="保存" Width="100" Height="40" 
                        Background="#457b9d" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="Medium" Cursor="Hand" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
