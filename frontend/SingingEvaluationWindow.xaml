<Window x:Class="SeeMusicApp.SingingEvaluationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="歌唱评估 - SeeMusic"
        Width="1480"
        Height="1080"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4F84A7"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#28476F"/>
        <SolidColorBrush x:Key="SoftTextBrush" Color="#98A2B3"/>
        <SolidColorBrush x:Key="BodyTextBrush" Color="#475467"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E9EEF5"/>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="Padding" Value="28"/>
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource SoftTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#344054"/>
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="BorderBrush" Value="#E4E7EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#344054"/>
            <Setter Property="Background" Value="#F7F9FC"/>
            <Setter Property="BorderBrush" Value="#E4E7EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
    </Window.Resources>

    <Border Margin="18" Background="#FBFBFC" CornerRadius="34">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FCFCFD" CornerRadius="34,34,0,0" Padding="28,22" BorderBrush="#EDF1F5" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnGoHome_Click">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="34" Height="34" CornerRadius="17" Background="#EAF2FF">
                                    <TextBlock Text="♪" FontSize="20" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="SeeMusic" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="#1F2937"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="上传标准音频与用户演唱音频进行双文件对比评估"
                                   Margin="28,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#2A3447"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="#98A2B3"
                               Text="后端接口：`/api/v1/singing/evaluate`"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="34,28,34,36">
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.02*"/>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="42" Height="42" CornerRadius="21" Background="#E8F1FF">
                                        <TextBlock Text="⌕" FontSize="24" Foreground="#60A5FA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Margin="14,0,0,0">
                                        <TextBlock Text="搜索标准歌曲" FontSize="22" FontWeight="Bold" Foreground="#344054"/>
                                        <TextBlock Text="输入歌曲名、歌手或关键词，当前版本请手动上传标准音频" FontSize="14" Foreground="#98A2B3"/>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Margin="0,22,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="132"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtSearchKeyword"
                                             Grid.Column="0"
                                             Height="60"
                                             Margin="0,0,16,0"
                                             Style="{StaticResource RoundedTextBoxStyle}"
                                             Text="例如：稻香 / 周杰伦 / keyword"/>
                                    <Button Grid.Column="1"
                                            Height="60"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="搜索"
                                            IsEnabled="False"
                                            ToolTip="当前版本请手动上传标准音频"/>
                                </Grid>

                                <Border Margin="0,20,0,0"
                                        Padding="18"
                                        CornerRadius="18"
                                        BorderBrush="#D0D5DD"
                                        BorderThickness="1"
                                        Background="#FCFCFD">
                                    <TextBlock Text="搜索后在这里选择标准歌曲。当前版本暂未接入真实曲库，请直接使用下方手动上传标准音频。"
                                               FontSize="15"
                                               Foreground="#98A2B3"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <Button x:Name="BtnChooseReferenceAudio"
                                        Margin="0,22,0,0"
                                        Height="60"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Content="手动上传标准音频"
                                        Click="BtnChooseReferenceAudio_Click"/>

                                <TextBlock x:Name="TxtSelectedReferenceAudio"
                                           Margin="2,18,0,0"
                                           Foreground="#2F6EA1"
                                           FontSize="16"
                                           Text="尚未选择标准音频"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" BorderBrush="#D9E2EC" BorderThickness="1.5">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="♬"
                                           FontSize="48"
                                           Foreground="#60A5FA"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="上传用户演唱音频"
                                           Margin="0,8,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#475467"/>
                                <TextBlock Text="请上传待对比的用户演唱版本"
                                           HorizontalAlignment="Center"
                                           FontSize="15"
                                           Foreground="#98A2B3"/>
                                <Button x:Name="BtnChoosePerformanceAudio"
                                        Margin="0,26,0,0"
                                        Height="56"
                                        Width="240"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Content="选择用户演唱音频"
                                        Click="BtnChoosePerformanceAudio_Click"/>
                                <TextBlock x:Name="TxtSelectedPerformanceAudio"
                                           Margin="0,18,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="18"
                                           Foreground="#2F6EA1"
                                           Text="尚未选择用户演唱音频"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="用户演唱音频类型"/>
                            <ComboBox x:Name="ComboUserAudioType" Height="58" Style="{StaticResource RoundedComboBoxStyle}">
                                <ComboBoxItem Content="with accompaniment" Tag="with_accompaniment" IsSelected="True"/>
                                <ComboBoxItem Content="clean vocal" Tag="clean_vocal"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="反馈语言"/>
                            <ComboBox x:Name="ComboFeedbackLanguage" Height="58" Style="{StaticResource RoundedComboBoxStyle}">
                                <ComboBoxItem Content="中文" Tag="zh-CN" IsSelected="True"/>
                                <ComboBoxItem Content="English" Tag="en-US"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="评分模型"/>
                            <ComboBox x:Name="ComboScoringModel" Height="58" Style="{StaticResource RoundedComboBoxStyle}">
                                <ComboBoxItem Content="balanced" Tag="balanced" IsSelected="True"/>
                                <ComboBoxItem Content="pitch focus" Tag="pitch_focus"/>
                                <ComboBoxItem Content="rhythm focus" Tag="rhythm_focus"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="阈值 (MS)"/>
                            <TextBox x:Name="TxtRhythmThreshold"
                                     Height="58"
                                     Style="{StaticResource RoundedTextBoxStyle}"
                                     Text="50"/>
                        </StackPanel>

                        <Button x:Name="BtnStartEval"
                                Grid.Column="2"
                                Height="118"
                                Style="{StaticResource PrimaryButtonStyle}"
                                FontSize="22"
                                Content="开始智能检测"
                                Click="BtnStartEval_Click"/>
                    </Grid>

                    <TextBlock x:Name="TxtEvalStatus"
                               Margin="2,0,0,32"
                               FontSize="14"
                               Foreground="#667085"
                               Text="请先上传标准音频与用户演唱音频，再开始对比评估。"/>

                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <TextBlock Text="▤" FontSize="24" Foreground="#22C55E"/>
                                <TextBlock Text="评估摘要" Margin="12,0,0,0" FontSize="22" FontWeight="Bold" Foreground="#2A3447"/>
                            </StackPanel>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="分析 ID"/>
                                    <TextBlock x:Name="TxtSummaryAnalysisId" Grid.Row="0" Grid.Column="1" FontSize="16" Foreground="#344054" Text="--"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="参考音频"/>
                                    <TextBlock x:Name="TxtSummaryReference" Grid.Row="1" Grid.Column="1" FontSize="16" Foreground="#344054" Text="--"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="用户 BPM"/>
                                    <TextBlock x:Name="TxtSummaryUserBpm" Grid.Row="2" Grid.Column="1" FontSize="16" Foreground="#344054" Text="--"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="参考 BPM"/>
                                    <TextBlock x:Name="TxtSummaryReferenceBpm" Grid.Row="3" Grid.Column="1" FontSize="16" Foreground="#344054" Text="--"/>
                                </Grid>
                            </Border>

                            <Border Margin="0,22,0,0" Style="{StaticResource SectionCardStyle}" Background="#EEF4FF">
                                <StackPanel>
                                    <TextBlock Text="智能纠错建议" FontSize="18" FontWeight="Bold" Foreground="#245BDB"/>
                                    <TextBlock x:Name="TxtCorrectionSuggestion"
                                               Margin="0,14,0,0"
                                               FontSize="16"
                                               Foreground="#2E5AAC"
                                               TextWrapping="Wrap"
                                               Text="等待后端返回分析结果。"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <TextBlock Text="▥" FontSize="24" Foreground="#4F84A7"/>
                                <TextBlock Text="综合评估报告" Margin="12,0,0,0" FontSize="22" FontWeight="Bold" Foreground="#2A3447"/>
                            </StackPanel>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="TxtOverallScore" Text="--" FontSize="56" FontWeight="Bold" Foreground="#4F84A7"/>
                                            <TextBlock Text="/ 100" Margin="12,18,0,0" FontSize="24" FontWeight="Bold" Foreground="#98A2B3"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#F2F4F7" Padding="18,8" CornerRadius="18" VerticalAlignment="Top">
                                            <TextBlock x:Name="TxtEvaluationBadge" Text="等待分析" FontSize="18" FontWeight="SemiBold" Foreground="#667085"/>
                                        </Border>
                                    </Grid>

                                    <Grid Margin="0,24,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="TxtPitchScoreLabel" Grid.Row="0" FontSize="16" Foreground="#475467" Text="音高准确度 --"/>
                                        <ProgressBar x:Name="PitchScoreProgress" Grid.Row="0" Margin="0,34,0,0" Height="10" Maximum="100" Value="0"/>

                                        <TextBlock x:Name="TxtRhythmScoreLabel" Grid.Row="1" Margin="0,26,0,0" FontSize="16" Foreground="#475467" Text="节奏准确度 --"/>
                                        <ProgressBar x:Name="RhythmScoreProgress" Grid.Row="1" Margin="0,60,0,0" Height="10" Maximum="100" Value="0"/>

                                        <TextBlock x:Name="TxtCoverageLabel" Grid.Row="2" Margin="0,52,0,0" FontSize="16" Foreground="#475467" Text="覆盖率 --"/>
                                        <ProgressBar x:Name="CoverageProgress" Grid.Row="2" Margin="0,86,0,0" Height="10" Maximum="100" Value="0"/>

                                        <TextBlock x:Name="TxtConsistencyLabel" Grid.Row="3" Margin="0,78,0,0" FontSize="16" Foreground="#475467" Text="一致性 --"/>
                                        <ProgressBar x:Name="ConsistencyProgress" Grid.Row="3" Margin="0,112,0,0" Height="10" Maximum="100" Value="0"/>

                                        <TextBlock x:Name="TxtMeanDeviationLabel" Grid.Row="4" Margin="0,104,0,0" FontSize="16" Foreground="#475467" Text="平均偏差 --"/>
                                    </Grid>

                                    <Button x:Name="BtnExportPdf"
                                            Margin="0,34,0,0"
                                            Height="58"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Content="生成并导出完整 PDF 报告"
                                            Click="BtnExportPdf_Click"
                                            IsEnabled="False"
                                            ToolTip="登录后可导出 PDF 报告"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,28">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <TextBlock Text="⌁" FontSize="24" Foreground="#3B82F6"/>
                            <TextBlock Text="音高对比分析" Margin="12,0,0,0" FontSize="22" FontWeight="Bold" Foreground="#2A3447"/>
                        </StackPanel>

                        <WrapPanel Margin="0,0,0,18">
                            <Border Width="320" Margin="0,0,18,18" Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="音高准确度" HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#98A2B3"/>
                                    <TextBlock x:Name="TxtPitchMetricScore" Margin="0,18,0,0" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="#4F84A7" Text="--"/>
                                </StackPanel>
                            </Border>
                            <Border Width="320" Margin="0,0,18,18" Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="平均偏差 (CENTS)" HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#98A2B3"/>
                                    <TextBlock x:Name="TxtPitchMetricDeviation" Margin="0,18,0,0" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="#4F84A7" Text="--"/>
                                </StackPanel>
                            </Border>
                            <Border Width="320" Margin="0,0,18,18" Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="±25CENTS 命中率" HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#98A2B3"/>
                                    <TextBlock x:Name="TxtPitchMetricHit25" Margin="0,18,0,0" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="#4F84A7" Text="--"/>
                                </StackPanel>
                            </Border>
                            <Border Width="320" Margin="0,0,0,18" Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="±50CENTS 命中率" HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#98A2B3"/>
                                    <TextBlock x:Name="TxtPitchMetricHit50" Margin="0,18,0,0" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="#4F84A7" Text="--"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <Grid Height="380">
                                    <Canvas x:Name="PitchChartCanvas" Width="1300" Height="330"/>
                                    <TextBlock x:Name="TxtPitchChartEmpty"
                                               Width="400"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="完成一次评估后，这里将展示音高对比曲线。"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#B3BDC9"
                                               TextAlignment="Center"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <Rectangle Width="40" Height="6" RadiusX="3" RadiusY="3" Fill="#4F84A7"/>
                                    <TextBlock Text="参考音高" Margin="8,0,22,0" Foreground="#667085" FontSize="15"/>
                                    <Rectangle Width="40" Height="6" RadiusX="3" RadiusY="3" Fill="#F97316"/>
                                    <TextBlock Text="用户音高" Margin="8,0,22,0" Foreground="#667085" FontSize="15"/>
                                    <Rectangle Width="40" Height="6" RadiusX="3" RadiusY="3" Fill="#82C6B0"/>
                                    <TextBlock Text="偏差 (cents)" Margin="8,0,0,0" Foreground="#667085" FontSize="15"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,28">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <TextBlock Text="♫" FontSize="24" Foreground="#F97316"/>
                            <TextBlock Text="节奏偏差明细" Margin="12,0,0,0" FontSize="22" FontWeight="Bold" Foreground="#2A3447"/>
                        </StackPanel>
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="TxtRhythmDetailHint"
                                           FontSize="18"
                                           Foreground="#98A2B3"
                                           Text="完成一次评估后，这里会展示后端返回的节奏误差分类与说明。"/>
                                <StackPanel x:Name="RhythmSegmentsPanel" Margin="0,20,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <TextBlock Text="♬" FontSize="24" Foreground="#A855F7"/>
                            <TextBlock Text="变调建议卡片" Margin="12,0,0,0" FontSize="22" FontWeight="Bold" Foreground="#2A3447"/>
                        </StackPanel>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="当前歌曲调性" FontSize="18" FontWeight="Bold" Foreground="#344054"/>
                                <Border Margin="0,14,0,0" Background="#F7F9FC" CornerRadius="18" Padding="18">
                                    <TextBlock x:Name="TxtDetectedKey"
                                               FontSize="30"
                                               FontWeight="Bold"
                                               Foreground="#28476F"
                                               Text="--"/>
                                </Border>

                                <TextBlock x:Name="TxtTransposeBaseSummary"
                                           Margin="0,18,0,0"
                                           FontSize="16"
                                           Foreground="#667085"
                                           TextWrapping="Wrap"
                                           Text="完成一次评估后，系统会自动识别标准音频的当前调性，并直接用于生成变调建议。"/>

                                <Grid Margin="0,26,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="原唱性别"/>
                                        <ComboBox x:Name="ComboSourceGender" Height="58" Style="{StaticResource RoundedComboBoxStyle}">
                                            <ComboBoxItem Content="男声" Tag="male" IsSelected="True"/>
                                            <ComboBoxItem Content="女声" Tag="female"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="目标性别"/>
                                        <ComboBox x:Name="ComboTargetGender" Height="58" Style="{StaticResource RoundedComboBoxStyle}">
                                            <ComboBoxItem Content="女声" Tag="female" IsSelected="True"/>
                                            <ComboBoxItem Content="男声" Tag="male"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <Button x:Name="BtnGenerateTransposeSuggestion"
                                        Margin="0,26,0,0"
                                        Height="64"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Background="#28476F"
                                        Content="生成变调建议"
