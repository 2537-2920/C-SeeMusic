<Window x:Class="SeeMusicApp.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="个人中心 - SeeMusic" Height="850" Width="1300"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FCFCFC" Offset="0"/>
            <GradientStop Color="#F3F4F6" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="35"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#8094A3B8" Opacity="0.15" BlurRadius="30" ShadowDepth="8"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChartBarStyle" TargetType="Border">
            <Setter Property="Background" Value="#94A3B8"/>
            <Setter Property="CornerRadius" Value="4,4,0,0"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Width" Value="80"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,15,10"/>
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="50,40,50,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnGoHome_Click" ToolTip="返回主界面">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="LogoIcon" Width="32" Height="32" Background="#457b9d" CornerRadius="4" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <TransformGroup>
                                                <RotateTransform Angle="0"/>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </TransformGroup>
                                        </Border.RenderTransform>
                                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                    </Border>
                                    <TextBlock Text="SeeMusic" FontWeight="Bold" FontSize="20" Foreground="#1d3557" Margin="10,0,5,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(RotateTransform.Angle)" To="12" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(RotateTransform.Angle)" To="0" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Line Y1="8" Y2="38" Stroke="#CBD5E1" StrokeThickness="1" Margin="15,0,20,0"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="个人中心" FontWeight="Bold" FontSize="28" Foreground="#1E293B"/>
                    <TextBlock Text="USER PROFILE &amp; SETTINGS" FontSize="11" Foreground="#94A3B8" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock Text="LAST UPDATE" FontSize="10" Foreground="#94A3B8" FontWeight="Bold" HorizontalAlignment="Right"/>
                <TextBlock Text="2026-04-03" FontSize="13" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="50,20,50,40">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3.5*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="6.5*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,25">
                        <StackPanel>
                            <Grid HorizontalAlignment="Center" Margin="0,0,0,15">
                                <Ellipse Width="110" Height="110" Fill="#A8DADC" Stroke="#F1F5F9" StrokeThickness="4"/>
                                <Ellipse Width="90" Height="90" Fill="#457b9d" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,10"/>

                                <Button Background="White" BorderThickness="1" BorderBrush="#E2E8F0" Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="16"/>
                                        </Style>
                                    </Button.Resources>
                                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" Foreground="#64748B" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </Grid>

                            <TextBlock Text="灵感创作者" FontSize="22" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                            <TextBlock Text="creator@seemusic.art" FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,5,0,30"/>

                            <Border BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" Padding="0,20,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="42" FontSize="20" FontWeight="Bold" Foreground="#457b9d" HorizontalAlignment="Center"/>
                                        <TextBlock Text="扒谱记录" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="15h" FontSize="20" FontWeight="Bold" Foreground="#457b9d" HorizontalAlignment="Center"/>
                                        <TextBlock Text="评估时长" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="128" FontSize="20" FontWeight="Bold" Foreground="#457b9d" HorizontalAlignment="Center"/>
                                        <TextBlock Text="收藏曲目" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Button Style="{StaticResource OutlineBtnStyle}" Margin="0,30,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="修改个人资料" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                <TextBlock Text="&#xEA18;" FontFamily="Segoe MDL2 Assets" Foreground="#457b9d" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="账号安全" FontWeight="Bold" FontSize="16" Foreground="#457b9d" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="登录密码" Foreground="#475569" FontWeight="Medium" VerticalAlignment="Center"/>
                                <Button Content="修改" Background="Transparent" BorderThickness="0" Foreground="#94A3B8" FontSize="13" HorizontalAlignment="Right" Cursor="Hand"/>
                            </Grid>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="隐私权限" Foreground="#475569" FontWeight="Medium" VerticalAlignment="Center"/>
                                <Button Content="管理" Background="Transparent" BorderThickness="0" Foreground="#94A3B8" FontSize="13" HorizontalAlignment="Right" Cursor="Hand"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="双重验证" Foreground="#475569" FontWeight="Medium" VerticalAlignment="Center"/>
                                <TextBlock Text="未开启" FontSize="13" Foreground="#CBD5E1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,25">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" Foreground="#457b9d" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="使用数据统计" FontWeight="Bold" FontSize="16" Foreground="#457b9d" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Background="#F8FAFC" CornerRadius="16" Height="220" Padding="20,20,20,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <Border Style="{StaticResource ChartBarStyle}" Height="60" Opacity="0.5"/>
                                        <TextBlock Text="Mon" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <Border Style="{StaticResource ChartBarStyle}" Height="95" Opacity="0.5"/>
                                        <TextBlock Text="Tue" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <Border Style="{StaticResource ChartBarStyle}" Height="140" Background="#2B5B84"/>
                                        <TextBlock Text="Wed" FontSize="11" FontWeight="Bold" Foreground="#457b9d" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <Border Style="{StaticResource ChartBarStyle}" Height="80" Opacity="0.5"/>
                                        <TextBlock Text="Thu" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <Border Style="{StaticResource ChartBarStyle}" Height="110" Opacity="0.5"/>
                                        <TextBlock Text="Fri" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="5" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                                        <Border Style="{StaticResource ChartBarStyle}" Height="45" Opacity="0.3"/>
                                        <TextBlock Text="Sat" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="#457b9d" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="系统偏好设置" FontWeight="Bold" FontSize="16" Foreground="#457b9d" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="音频引擎" FontSize="13" Foreground="#64748B" Margin="0,0,0,10"/>
                                    <ComboBox Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Padding="12" FontSize="14" FontWeight="Medium" Foreground="#1E293B" Margin="0,0,0,30">
                                        <ComboBoxItem IsSelected="True">系统默认音频设备</ComboBoxItem>
                                        <ComboBoxItem>ASIO: External Interface</ComboBoxItem>
                                        <ComboBoxItem>DirectSound: Primary</ComboBoxItem>
                                    </ComboBox>

                                    <TextBlock Text="界面主题" FontSize="13" Foreground="#64748B" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Background="#457b9d" Foreground="White" FontWeight="Medium" BorderThickness="0" Padding="0,12" Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </Style>
                                            </Button.Resources>
                                            <TextBlock Text="浅色音乐风"/>
                                        </Button>
                                        <Button Grid.Column="2" Style="{StaticResource OutlineBtnStyle}">
                                            <TextBlock Text="深夜爵士风"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="默认导出格式" FontSize="13" Foreground="#64748B" Margin="0,0,0,10"/>
                                    <WrapPanel Margin="0,0,0,25">
                                        <CheckBox Content="MIDI" IsChecked="True"/>
                                        <CheckBox Content="XML" IsChecked="True"/>
                                        <CheckBox Content="PDF"/>
                                        <CheckBox Content="PNG"/>
                                    </WrapPanel>

                                    <Button Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Cursor="Hand" Margin="0,15,0,0" Click="BtnClearCache_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="TxtCache" Text="清除系统缓存 (1.2GB)" FontWeight="Medium" Foreground="#EF4444" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,20,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="用户协议" FontSize="12" Foreground="#94A3B8" Margin="0,0,20,0" Cursor="Hand"/>
                            <TextBlock Text="隐私政策" FontSize="12" Foreground="#94A3B8" Margin="0,0,20,0" Cursor="Hand"/>
                            <TextBlock Text="关于我们" FontSize="12" Foreground="#94A3B8" Cursor="Hand"/>
                        </StackPanel>
                        <TextBlock Text="SeeMusic Studio Version 4.2.0-Alpha" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>