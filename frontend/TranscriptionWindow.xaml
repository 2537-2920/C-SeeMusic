<Window x:Class="SeeMusicApp.TranscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="智能扒谱 - SeeMusic" Height="850" Width="1300"
        WindowStartupLocation="CenterScreen" Background="#f0f2f5"
        WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="ToolBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="BorderBrush" Value="#edf2f7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f7fafc"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.05"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveToolBtnStyle" TargetType="Button" BasedOn="{StaticResource ToolBtnStyle}">
            <Setter Property="Background" Value="#457b9d"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#457b9d"/>
        </Style>

        <Style x:Key="RightPanelBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#CCFFFFFF" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Panel.ZIndex="10">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnGoHome_Click" ToolTip="返回主界面">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border x:Name="LogoIcon" Width="32" Height="32" Background="#457b9d" CornerRadius="4" RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <TransformGroup>
                                                    <RotateTransform Angle="0"/>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </TransformGroup>
                                            </Border.RenderTransform>
                                            <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                        </Border>
                                        <TextBlock Text="SeeMusic" FontWeight="Bold" FontSize="20" Foreground="#1d3557" Margin="10,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="v2026.4" Foreground="#999" FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    </StackPanel>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(RotateTransform.Angle)" To="12" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(RotateTransform.Angle)" To="0" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="LogoIcon" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Line Y1="10" Y2="30" Stroke="#E2E8F0" StrokeThickness="1" Margin="15,0,5,0"/>
                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" Foreground="#457b9d" FontSize="16" Margin="15,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="未命名项目.musicxml" Foreground="#666" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F3F4F6" CornerRadius="8" Padding="4" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="编辑视图" Background="White" Foreground="#333" FontWeight="Bold" BorderThickness="0" Padding="12,4" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="混合视图" Background="Transparent" Foreground="#999" FontWeight="Bold" BorderThickness="0" Padding="12,4" Cursor="Hand"/>
                        </StackPanel>
                    </Border>

                    <Button Background="#1d3557" Foreground="White" BorderThickness="0" Padding="15,8" FontWeight="Bold" Margin="0,0,15,0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="导出" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Ellipse Width="32" Height="32" Fill="#E2E8F0" Stroke="#CBD5E1" StrokeThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="288"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" Padding="20" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="音频输入源" FontSize="12" FontWeight="Bold" Foreground="#A0AEC0" Margin="0,0,0,15"/>
                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="80"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="80"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource ActiveToolBtnStyle}">
                                    <StackPanel>
                                        <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock Text="本地音频" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnMic" Grid.Row="0" Grid.Column="2" Style="{StaticResource ToolBtnStyle}" Click="BtnMic_Click">
                                    <StackPanel>
                                        <TextBlock x:Name="IconMic" Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="TxtMic" Text="麦克风录音" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource ToolBtnStyle}">
                                    <StackPanel>
                                        <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock Text="视频提取" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource ToolBtnStyle}">
                                    <StackPanel>
                                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock Text="内置示例" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Background="#F0F7FA" BorderBrush="#E0F0F5" BorderThickness="1" CornerRadius="16" Padding="15" Margin="0,0,0,15">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="&#xE1CE;" FontFamily="Segoe MDL2 Assets" Foreground="#457b9d" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="AI 智能分离引擎" FontSize="12" FontWeight="Bold" Foreground="#457b9d" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid Margin="0,5">
                                        <TextBlock Text="旋律分离" FontSize="12" Foreground="#666"/>
                                        <CheckBox IsChecked="True" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <TextBlock Text="伴奏分离" FontSize="12" Foreground="#666"/>
                                        <CheckBox IsChecked="True" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,5">
                                        <TextBlock Text="节奏分析" FontSize="12" Foreground="#666"/>
                                        <CheckBox IsChecked="True" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="音乐风格判断" FontSize="11" FontWeight="Bold" Foreground="#A0AEC0" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="#F3F4F6" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                    <TextBlock Text="古典" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                                </Border>
                                <Border Background="#E6F0F5" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                    <TextBlock Text="流行 (Pop)" FontSize="11" FontWeight="Bold" Foreground="#457b9d"/>
                                </Border>
                                <Border Background="#F3F4F6" CornerRadius="4" Padding="8,4">
                                    <TextBlock Text="爵士" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                                </Border>
                            </StackPanel>

                            <Button Background="#457b9d" Foreground="White" FontWeight="Bold" Padding="0,12" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="12"/>
                                    </Style>
                                </Button.Resources>
                                <TextBlock Text="重新分析音频"/>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" Padding="20">
                        <StackPanel>
                            <TextBlock Text="音轨管理" FontSize="12" FontWeight="Bold" Foreground="#A0AEC0" Margin="0,0,0,10"/>
                            <Border Background="White" BorderBrush="#F1F5F9" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                <Grid>
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" Foreground="#457b9d" VerticalAlignment="Center"/>
                                    <TextBlock Text="主旋律 (Piano)" FontSize="12" FontWeight="Bold" Margin="25,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="&#xE767;" FontFamily="Segoe MDL2 Assets" Foreground="#CCC" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="White" BorderBrush="#F1F5F9" BorderThickness="1" CornerRadius="8" Padding="10" Opacity="0.5">
                                <Grid>
                                    <TextBlock Text="&#xE16F;" FontFamily="Segoe MDL2 Assets" Foreground="#999" VerticalAlignment="Center"/>
                                    <TextBlock Text="伴奏音轨" FontSize="12" FontWeight="Bold" Margin="25,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="&#xE74F;" FontFamily="Segoe MDL2 Assets" Foreground="#CCC" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" Margin="0,40">

                    <Grid Width="850" Margin="0,0,0,20">
                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="6" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Button Background="Transparent" BorderThickness="0" Padding="8" Foreground="#666" ToolTip="撤销">
                                    <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="8" Foreground="#666" ToolTip="重做">
                                    <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets"/>
                                </Button>
                                <Line Y1="5" Y2="20" Stroke="#E2E8F0" Margin="5,0"/>
                                <Button Background="#F0F7FA" BorderThickness="0" Padding="8" Foreground="#457b9d" ToolTip="选择指针">
                                    <TextBlock Text="&#xE8B0;" FontFamily="Segoe MDL2 Assets"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="8" Foreground="#666" ToolTip="添加音符">
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="8" Foreground="#666" ToolTip="删除">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/>
                                </Button>
                                <Line Y1="5" Y2="20" Stroke="#E2E8F0" Margin="5,0"/>
                                <Button Background="Transparent" BorderThickness="0" Padding="8" Foreground="#666" ToolTip="升调">
                                    <TextBlock Text="&#xE110;" FontFamily="Segoe MDL2 Assets"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="8" Foreground="#666" ToolTip="降调">
                                    <TextBlock Text="&#xE1FD;" FontFamily="Segoe MDL2 Assets"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="6" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#F8FAFC" BorderBrush="#F1F5F9" BorderThickness="1" CornerRadius="8" Padding="12,4" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="拍号" FontSize="12" FontWeight="Bold" Foreground="#999" Margin="0,0,5,0"/>
                                        <TextBlock Text="4/4" FontSize="12" FontWeight="Black" Foreground="#1d3557"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F8FAFC" BorderBrush="#F1F5F9" BorderThickness="1" CornerRadius="8" Padding="12,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="BPM" FontSize="12" FontWeight="Bold" Foreground="#999" Margin="0,0,5,0"/>
                                        <TextBlock Text="120" FontSize="12" FontWeight="Black" Foreground="#1d3557"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Width="850" MinHeight="800" CornerRadius="4" Background="#fffdf5">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="30" ShadowDepth="10"/>
                        </Border.Effect>

                        <Border CornerRadius="4" Padding="40,60">
                            <Border.Background>
                                <DrawingBrush Viewport="0,0,20,20" ViewportUnits="Absolute" TileMode="Tile">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing Brush="#E0E0E0">
                                            <GeometryDrawing.Geometry>
                                                <EllipseGeometry RadiusX="1" RadiusY="1" Center="10,10" />
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Border.Background>

                            <StackPanel x:Name="PaperContainer">
                                <TextBlock Text="夜的钢琴曲 (AI 生成稿)" FontSize="32" FontFamily="KaiTi, Georgia" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,50"/>

                                <Canvas x:Name="MainStaffCanvas" Background="Transparent" Height="100" Margin="0,0,0,60" MouseLeftButtonDown="MainStaffCanvas_MouseLeftButtonDown" Cursor="Pen">
                                    <TextBlock Text="&#x1D11E;" FontFamily="Segoe UI Symbol, Arial Unicode MS" FontSize="60" Foreground="#333" Canvas.Left="10" Canvas.Top="-15"/>
                                    <TextBlock Text="4" FontSize="14" FontWeight="Bold" Canvas.Left="45" Canvas.Top="6"/>
                                    <TextBlock Text="4" FontSize="14" FontWeight="Bold" Canvas.Left="45" Canvas.Top="22"/>

                                    <Line X1="70" Y1="0" X2="770" Y2="0" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="12" X2="770" Y2="12" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="24" X2="770" Y2="24" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="36" X2="770" Y2="36" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="48" X2="770" Y2="48" Stroke="#bdc3c7" StrokeThickness="1"/>

                                    <Line X1="385" Y1="0" X2="385" Y2="48" Stroke="#999" StrokeThickness="1"/>
                                    <Line X1="770" Y1="0" X2="770" Y2="48" Stroke="#333" StrokeThickness="2"/>
                                </Canvas>

                                <Canvas Height="60" Margin="0,0,0,60">
                                    <Line X1="70" Y1="0" X2="770" Y2="0" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="12" X2="770" Y2="12" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="24" X2="770" Y2="24" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="36" X2="770" Y2="36" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="48" X2="770" Y2="48" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="385" Y1="0" X2="385" Y2="48" Stroke="#999" StrokeThickness="1"/>
                                    <Line X1="770" Y1="0" X2="770" Y2="48" Stroke="#333" StrokeThickness="2"/>
                                </Canvas>

                                <Canvas Height="60">
                                    <Line X1="70" Y1="0" X2="770" Y2="0" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="12" X2="770" Y2="12" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="24" X2="770" Y2="24" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="36" X2="770" Y2="36" Stroke="#bdc3c7" StrokeThickness="1"/>
                                    <Line X1="70" Y1="48" X2="770" Y2="48" Stroke="#bdc3c7" StrokeThickness="1"/>
                                </Canvas>

                                <TextBlock Text="--- 点击第一行五线谱任意位置添加音符 ---" FontStyle="Italic" Foreground="#CCC" FontSize="12" HorizontalAlignment="Center" Margin="0,80,0,0"/>
                            </StackPanel>
                        </Border>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0" Padding="25">
                <StackPanel>
                    <TextBlock Text="导出格式" FontSize="12" FontWeight="Bold" Foreground="#A0AEC0" Margin="0,0,0,20"/>

                    <Button Style="{StaticResource RightPanelBtnStyle}" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#FEE2E2" Width="40" Height="40" CornerRadius="12">
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="PDF 打印稿" FontWeight="Bold" FontSize="14" Foreground="#333"/>
                                <TextBlock Text="标准高质量乐谱" FontSize="10" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource RightPanelBtnStyle}" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#E0F2FE" Width="40" Height="40" CornerRadius="12">
                                <TextBlock Text="&#xE189;" FontFamily="Segoe MDL2 Assets" Foreground="#3B82F6" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="MIDI 数据" FontWeight="Bold" FontSize="14" Foreground="#333"/>
                                <TextBlock Text="用于 DAW 或编曲" FontSize="10" Foreground="#999" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource RightPanelBtnStyle}" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#DCFCE7" Width="40" Height="40" CornerRadius="12">
                                <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" Foreground="#22C55E" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="PNG 图片" FontWeight="Bold" FontSize="14" Foreground="#333"/>
