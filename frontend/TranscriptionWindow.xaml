<Window x:Class="SeeMusicApp.TranscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="智能识谱 - SeeMusic"
        Width="1500"
        Height="980"
        WindowStartupLocation="CenterScreen"
        Background="#EDF3FB"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F7FAFF"/>
            <Setter Property="Foreground" Value="#294A6A"/>
            <Setter Property="BorderBrush" Value="#D7E4F2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
            <Setter Property="Background" Value="#25466B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#25466B"/>
        </Style>

        <Style x:Key="DisabledTabStyle" TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
            <Setter Property="Foreground" Value="#96A3B8"/>
            <Setter Property="Background" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#E6EDF6"/>
            <Setter Property="IsEnabled" Value="False"/>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7FBFF"/>
            <Setter Property="BorderBrush" Value="#DCE7F3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="30" Background="#EDF3FB" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="30"
                    Padding="28"
                    BorderBrush="#DCE8F4"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BtnGoHome_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="64" Height="64" Background="#3B76A6" CornerRadius="20">
                                    <TextBlock Text="♪" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="SeeMusic"
                                           Margin="18,0,0,0"
                                           FontSize="38"
                                           FontWeight="Bold"
                                           Foreground="#1E3C62"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Border Width="1" Height="70" Background="#E2EAF3" Margin="26,0,24,0"/>
                        <StackPanel>
                            <TextBlock Text="智能识谱" FontSize="32" FontWeight="Bold" Foreground="#213B63"/>
                            <TextBlock Text="在工作台中完成识谱、分析、预览和本地导出。"
                                       Margin="0,10,0,0"
                                       FontSize="17"
                                       Foreground="#6C7B92"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#F9FCFF"
                                BorderBrush="#E0EBF6"
                                BorderThickness="1"
                                CornerRadius="24"
                                Padding="20,14"
                                Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="HealthStatusDot" Width="14" Height="14" Fill="#67B67B" Margin="0,0,10,0"/>
                                <TextBlock x:Name="TxtHealthStatus" Text="服务可用" FontSize="14" FontWeight="SemiBold" Foreground="#5C6A80"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F9FCFF"
                                BorderBrush="#E0EBF6"
                                BorderThickness="1"
                                CornerRadius="24"
                                Padding="20,14"
                                Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="当前双手钢琴谱" FontSize="14" Foreground="#6C7B92"/>
                                <TextBlock x:Name="TxtModeStatus" Text=" 已连接" FontSize="14" FontWeight="Bold" Foreground="#1E3C62"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F9FCFF"
                                BorderBrush="#E0EBF6"
                                BorderThickness="1"
                                CornerRadius="26"
                                Padding="12,10"
                                Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="54" Height="54" Background="#F4D1B3" CornerRadius="27">
                                    <TextBlock Text="☺" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="TxtDemoUserName" Text="xxxx" Margin="14,0,4,0" FontSize="17" FontWeight="Bold" Foreground="#283F62" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Width="44"
                                Height="44"
                                Background="#F4F7FB"
                                BorderBrush="#DCE7F3"
                                BorderThickness="1"
                                Cursor="Hand"
                                Click="BtnClose_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="22"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock Text="×" FontSize="18" Foreground="#60708C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,20,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="White"
                                CornerRadius="28"
                                Padding="26"
                                BorderBrush="#DCE8F4"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="识谱准备" FontSize="15" FontWeight="Bold" Foreground="#7DB9C5"/>
                                <TextBlock Text="基础信息" Margin="0,10,0,24" FontSize="24" FontWeight="Bold" Foreground="#1F3F63"/>

                                <TextBlock Text="项目标题" FontSize="16" FontWeight="SemiBold" Foreground="#6B7A92"/>
                                <TextBox x:Name="TxtProjectTitle"
                                         Margin="0,12,0,24"
                                         Padding="16"
                                         FontSize="15"
                                         Background="#FAFCFF"
                                         BorderBrush="#D8E4F0"
                                         BorderThickness="1"
                                         Text="我的智能识谱项目"/>

                                <TextBlock Text="上传识谱音频" FontSize="16" FontWeight="SemiBold" Foreground="#6B7A92"/>
                                <Border Background="#FAFCFF"
                                        BorderBrush="#D8E4F0"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="14"
                                        Margin="0,14,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button x:Name="BtnChooseAudio"
                                                    Content="选择文件"
                                                    Style="{StaticResource PillButtonStyle}"
                                                    Click="BtnChooseAudio_Click"/>
                                            <TextBlock x:Name="TxtSelectedAudio"
                                                       Margin="14,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       Foreground="#617086"
                                                       Text="未选择任何文件"/>
                                        </StackPanel>
                                        <TextBlock Text="支持 WAV、MP3、M4A、OGG。选择音频后直接点击下方生成钢琴谱即可。"
                                                   Margin="0,16,0,0"
                                                   FontSize="14"
                                                   Foreground="#7B8CA5"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <ProgressBar x:Name="TranscriptionProgressBar"
                                             Height="18"
                                             Margin="0,18,0,0"
                                             Background="#EEF4FA"
                                             Foreground="#4B86B6"
                                             Maximum="100"
                                             Value="0"/>
                                <TextBlock x:Name="TxtTranscriptionStatus"
                                           Margin="0,12,0,0"
                                           FontSize="14"
                                           Foreground="#6B7A92"
                                           TextWrapping="Wrap"
                                           Text="等待选择音频文件。"/>

                                <Button x:Name="BtnGenerateScore"
                                        Margin="0,26,0,0"
                                        Height="66"
                                        Content="生成双手钢琴谱"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="BtnGenerateScore_Click"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White"
                                CornerRadius="28"
                                Padding="26"
                                BorderBrush="#DCE8F4"
                                BorderThickness="1"
                                Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="当前状态" FontSize="15" FontWeight="Bold" Foreground="#7DB9C5"/>
                                <TextBlock Text="乐谱概览" Margin="0,10,0,24" FontSize="24" FontWeight="Bold" Foreground="#1F3F63"/>

                                <UniformGrid Columns="2" Rows="2">
                                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,14">
                                        <StackPanel>
                                            <TextBlock Text="速度" FontSize="14" Foreground="#7A8AA0"/>
                                            <TextBlock x:Name="TxtTempo" Text="--" Margin="0,16,0,0" FontSize="26" FontWeight="Bold" Foreground="#1E3C62"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricCardStyle}" Margin="10,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="拍号" FontSize="14" Foreground="#7A8AA0"/>
                                            <TextBlock x:Name="TxtMeter" Text="--/--" Margin="0,16,0,0" FontSize="26" FontWeight="Bold" Foreground="#1E3C62"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="调号" FontSize="14" Foreground="#7A8AA0"/>
                                            <TextBlock x:Name="TxtKey" Text="--" Margin="0,16,0,0" FontSize="26" FontWeight="Bold" Foreground="#1E3C62"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricCardStyle}" Margin="10,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="小节数" FontSize="14" Foreground="#7A8AA0"/>
                                            <TextBlock x:Name="TxtMeasures" Text="--" Margin="0,16,0,0" FontSize="26" FontWeight="Bold" Foreground="#1E3C62"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <TextBlock Text="当前乐谱的速度、拍号、调号与小节数会在生成后自动同步到这里。"
                                           Margin="0,18,0,0"
                                           FontSize="14"
                                           Foreground="#7B8CA5"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="28"
                        Padding="28"
                        BorderBrush="#DCE8F4"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="识谱结果" FontSize="15" FontWeight="Bold" Foreground="#7DB9C5"/>
                                <TextBlock x:Name="TxtScoreTitle"
                                           Text="双手钢琴谱预览"
                                           Margin="0,10,0,0"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="#1F3F63"/>
                                <TextBlock x:Name="TxtScoreSubtitle"
                                           Text="当前页面会固定展示只读钢琴谱，并同步展示拍号、速度与双手分配摘要。"
                                           Margin="0,18,0,0"
                                           FontSize="15"
                                           Foreground="#6C7B92"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button Content="钢琴"
                                        Style="{StaticResource PillButtonStyle}"
                                        Background="#F0F8FF"
                                        BorderBrush="#C8DDF0"
                                        FontWeight="Bold"/>
                                <Button Content="古筝" Style="{StaticResource DisabledTabStyle}" Margin="10,0,0,0"/>
                                <Button Content="吉他" Style="{StaticResource DisabledTabStyle}" Margin="10,0,0,0"/>
                                <Button Content="笛子" Style="{StaticResource DisabledTabStyle}" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,24,0,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="BtnPrevPage"
                                    Grid.Column="0"
                                    Content="&lt;"
                                    Width="64"
                                    Style="{StaticResource PillButtonStyle}"
                                    Click="BtnPrevPage_Click"/>
                            <Border Grid.Column="1"
                                    Background="#F8FBFF"
                                    BorderBrush="#DCE8F4"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="24,12"
                                    Margin="14,0,0,0">
                                <TextBlock x:Name="TxtPageIndicator" Text="第 1 / 1 页" FontSize="16" FontWeight="Bold" Foreground="#1F3F63"/>
                            </Border>
                            <Button x:Name="BtnNextPage"
                                    Grid.Column="2"
                                    Content="&gt;"
                                    Width="64"
                                    Style="{StaticResource PillButtonStyle}"
                                    Margin="14,0,0,0"
                                    Click="BtnNextPage_Click"/>
                            <Button x:Name="BtnRefreshClear"
                                    Grid.Column="4"
                                    Content="刷新并清空"
                                    Style="{StaticResource PillButtonStyle}"
                                    Margin="0,0,14,0"
                                    Click="BtnRefreshClear_Click"/>
                            <Button x:Name="BtnExportPdf"
                                    Grid.Column="5"
                                    Content="导出 PDF"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="BtnExportPdf_Click"/>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="#FCFEFF"
                                BorderBrush="#DCE8F4"
                                BorderThickness="1"
                                CornerRadius="28"
                                Padding="18">
                            <WebBrowser x:Name="ScorePreviewBrowser"/>
                        </Border>

                        <Border Grid.Row="3"
                                Background="#F8FBFF"
                                BorderBrush="#DCE8F4"
                                BorderThickness="1"
                                CornerRadius="24"
                                Padding="24"
                                Margin="0,22,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Text="右手旋律摘要" FontSize="16" FontWeight="Bold" Foreground="#213B63"/>
                                    <TextBlock x:Name="TxtMelodySummary"
                                               Margin="0,14,0,0"
                                               FontSize="14"
                                               Foreground="#6C7B92"
                                               TextWrapping="Wrap"
                                               Text="等待识谱结果。"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="18,0">
                                    <TextBlock Text="左手伴奏摘要" FontSize="16" FontWeight="Bold" Foreground="#213B63"/>
                                    <TextBlock x:Name="TxtAccompanimentSummary"
                                               Margin="0,14,0,0"
                                               FontSize="14"
                                               Foreground="#6C7B92"
                                               TextWrapping="Wrap"
                                               Text="等待识谱结果。"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="18,0,0,0">
                                    <TextBlock Text="分配与提示" FontSize="16" FontWeight="Bold" Foreground="#213B63"/>
                                    <TextBlock x:Name="TxtAssignmentSummary"
                                               Margin="0,14,0,0"
                                               FontSize="14"
                                               Foreground="#6C7B92"
                                               TextWrapping="Wrap"
                                               Text="生成后会在这里展示双手分配与处理说明。"/>
                                    <StackPanel x:Name="WarningsPanel" Margin="0,14,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="22"
                    Padding="24"
                    BorderBrush="#DCE8F4"
                    BorderThickness="1">
                <TextBlock x:Name="TxtFooterStatus"
                           Text="服务连接正常，现在可以开始识谱和预览。"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#233B63"/>
            </Border>
        </Grid>
    </Border>
</Window>
