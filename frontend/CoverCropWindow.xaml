<Window x:Class="SeeMusicApp.CoverCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="调整封面" Height="380" Width="400"
        WindowStartupLocation="CenterOwner" Background="Transparent"
        WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border CornerRadius="28" Background="White" BorderBrush="#F1F5F9" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.15" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="30,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="调整封面位置" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="按住鼠标左键拖拽图片，边框即为最终裁剪范围" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#94A3B8"/>
                </Button>
            </Grid>

            <!-- Drag Viewport Border (Exactly 180:200 aspect ratio) -->
            <Border x:Name="DragBorder" Grid.Row="1" Width="180" Height="200" CornerRadius="16" BorderBrush="#457b9d" BorderThickness="2.5" Background="#F8FAFC" ClipToBounds="True" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas x:Name="DragCanvas" Background="Transparent" ClipToBounds="True" Cursor="SizeAll"
                        MouseLeftButtonDown="DragCanvas_MouseLeftButtonDown"
                        MouseMove="DragCanvas_MouseMove"
                        MouseLeftButtonUp="DragCanvas_MouseLeftButtonUp">
                    <Image x:Name="SourceImage" Stretch="Fill" Loaded="SourceImage_Loaded">
                        <Image.RenderTransform>
                            <TranslateTransform x:Name="ImageTranslate" X="0" Y="0"/>
                        </Image.RenderTransform>
                    </Image>
                </Canvas>
            </Border>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="取消" Width="80" Height="36" Background="#F1F5F9" Foreground="#64748B" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,12,0" Click="BtnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="确定" Width="100" Height="36" Background="#457b9d" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnConfirm_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
